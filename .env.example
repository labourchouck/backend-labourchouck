NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/labourchowck
JWT_SECRET=change-me-to-long-random-string
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:5173
# Plain OTP is printed to the server terminal when NODE_ENV is not production.
# Set to true to also print OTP when NODE_ENV=production (e.g. staging only).
OTP_DEV_LOG=true
# Client review: OTP = last 6 digits of mobile (e.g. 9876543210 → 543210).
# Auto-on when NODE_ENV is not production; set true on production demo hosts.
OTP_BYPASS_LAST6=true
SEED_ADMIN_EMAIL=admin@labourchowck.local
SEED_ADMIN_PASSWORD=ChangeMe@123
SEED_ADMIN_PHONE=8999999999
